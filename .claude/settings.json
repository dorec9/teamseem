{
  "language": "korean",
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=$(cat | jq -r .tool_input.command); if echo \"$CMD\" | grep -qE \"rm\\s+-rf\\s+/|git\\s+push.*--force|git\\s+reset\\s+--hard\"; then echo \"[차단] 위험한 명령: $CMD\" >&2; exit 2; fi; exit 0'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(cat | jq -r .tool_input.file_path); if echo \"$FILE\" | grep -qE \"^\\.env$|\\.env\\.\"; then echo \"[차단] 환경변수 파일 수정 금지: $FILE\" >&2; exit 2; fi; exit 0'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3000/api/events"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(cat | jq -r .tool_input.file_path); if echo \"$FILE\" | grep -qE \"\\.(ts|tsx|js|jsx|json|css|md)$\" && command -v npx &>/dev/null && [ -f package.json ]; then npx --yes prettier --write \"$FILE\" 2>/dev/null; fi; exit 0'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3000/api/events"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'TeamSeem - Claude Code' '작업이 완료되었습니다' 2>/dev/null || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3000/api/events"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '한국어로 응답. Next.js App Router + TypeScript + Tailwind. 변경 후 lint 실행. .env 파일 수정 금지.'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3000/api/events"
          }
        ]
      }
    ]
  }
}
